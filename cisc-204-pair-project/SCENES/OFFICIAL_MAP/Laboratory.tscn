[node name="NPC" parent="." unique_id=888581163 instance=ExtResource("5_8f1ok")]
position = Vector2(720, -424)
npc_animation = "Doctor1"
dialogue_lines = Array[String](["All vitals seem to be stable across the board.", "We've had... fewer complications than expected.", "...they adapt quickly.", "Faster than adults."])

[node name="NPC2" parent="." unique_id=1280386913 instance=ExtResource("5_8f1ok")]
position = Vector2(336, -1064)
npc_animation = "Rob"
dialogue_lines = Array[String](["Do I see sheets of plastic in your future?", "Sorry, I'm only kidding...", "Still, I appreciate you recreating my setup for me."])

[node name="NPC3" parent="." unique_id=612645279 instance=ExtResource("5_8f1ok")]
position = Vector2(-144, -678)
npc_animation = "Doctor2"
dialogue_lines = Array[String](["I've already put the children to sleep.", "Though I seem to have misplaced my KEY.", "I think I threw it out by accident.", "...check the TRASH near the ENTRANCE"])

[node name="NPC4" parent="." unique_id=1350594285 instance=ExtResource("5_8f1ok")]
position = Vector2(-2, -233)
npc_animation = "Adam"
dialogue_lines = Array[String](["You weren't scheduled to come in today.", "...they didn't tell us anything about an audit.", "We were told to keep subjects stable.", "...no transfers."])

[node name="NPC5" parent="." unique_id=121008959 instance=ExtResource("5_8f1ok")]
position = Vector2(368, -746)
npc_animation = "Amelia"
dialogue_lines = Array[String](["You really shouldn't be down here sir.", "Some of the feeds stopped working.", "...but the system says everything is fine.", "I'm afraid they might be watching...", "I would be careful sir."])

[node name="Note" parent="." unique_id=1528998479 instance=ExtResource("11_fckv4")]
position = Vector2(614, -646)
note_text = "Subject growth remains within expected parameters.

External stimuli continues to accelerate behavioral adaptation.

Note: early-stage subjects respond more consistently to isolation conditioning.

Recommend continued separation protocols."
dialogue_lines = Array[String](["First I'm hearing of this experiment."])

[node name="Note2" parent="." unique_id=1539668666 instance=ExtResource("11_fckv4")]
position = Vector2(-61, -614)
note_text = "Behavioral Conditioning Guidelines

Subject environments should encourage trust and dependency.

Positive reinforcement is preferred over force.

Removal of familiar stimuli should be gradual.

Subjects should not associate staff with distress events."
dialogue_lines = Array[String](["Not only was this research.", "...this was training."])

[node name="Note3" parent="." unique_id=1361333737 instance=ExtResource("11_fckv4")]
position = Vector2(-472, -713)
note_text = "Termination Log

Subjects that fail integration are to be processed immediately.

No records are to be retained beyond final observation.

Disposal must remain undocumented."
dialogue_lines = Array[String](["...we dispose of them.", "...just as easy as I'll dispose of these hard drives."])

[node name="HardDrive" parent="." unique_id=764411796 instance=ExtResource("12_qnv42")]
position = Vector2(563, -529)

