[node name="Note4" parent="." unique_id=1513159677 instance=ExtResource("11_fckv4")]
position = Vector2(294, -732)
note_text = "External Compliance Arrangement

Certain external contractors have been granted controlled access to disposal resources.

All interactions must remain off-record.

Do not interfere with independent correction operations."
dialogue_lines = Array[String](["...we don't only run experiments.", "...we manage outcomes."])

[node name="Note5" parent="." unique_id=797941331 instance=ExtResource("11_fckv4")]
position = Vector2(297, -987)
note_text = "My Dark Passenger is quiet now. The balance is restored. He was a perfect fit for the Code, predatory, unrepentant, hidden in plain sight, just like me.  He thought he was the one pulling the strings, but in the end, he was just a loose end that needed snipping.

One more slide to add to the collection. The current in the Harbor is strong tonight, it'll carry the weight of his sins far out into sea. "
dialogue_lines = Array[String](["Just make sure the current actually takes it this time.", "We wouldn't want another public showing of the Butchers work."])

