[node name="Note" parent="." unique_id=1528998479 instance=ExtResource("7_7n44a")]
position = Vector2(-124, -181)
note_text = "If you're reading this, I couldn't reach you directly.  The FIB audit has been moved up. They'll be here by morning.

You need to WIPE the facility records. All of them.
The HARD DRIVES are split between the OFFICE and the LAB. 

I've locked down what I could, but I can't protect you from the system this time."
dialogue_lines = Array[String](["This sounds serious.", "I should start in the OFFICE and grab my LEVEL 1 KEYCARD while I'm there."])

